# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL=""

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL=""

AUTH_SECRET=
AUTH_URL="http://localhost:3000"

NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=

MOBILE_API_KEY=replace-with-a-long-random-value

# Dedicated secret for the GitHub Actions keep-alive workflow.
# MUST be distinct from MOBILE_API_KEY. Sent as the `x-keepalive-key` header.
SUPABASE_KEEPALIVE_KEY=

SEED_ADMIN_PASSWORD=
SEED_SELLER_PASSWORD=